# SmileHub Gestão
DATABASE_URL="postgresql://usuario:senha@host.neon.tech/db?sslmode=require"
NEON_AUTH_COOKIE_SECRET="gere-um-token-forte-com-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="https://gestao.smilehub.com.br"
NEXT_PUBLIC_PUBLIC_SITE_DOMAIN="smilehub.com.br"

# Opcional: health check do banco
DB_HEALTHCHECK_TOKEN=""

# Stripe - assinatura online (server-side; nunca expor secrets no frontend)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_ANNUAL=""
# Opcional se usar componentes públicos do Stripe no frontend futuramente
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# NFSe - usar somente no servidor; nunca expor no frontend
NFSE_PROVIDER=national
NFSE_ENVIRONMENT=homologation
NFSE_API_BASE_URL=
NFSE_API_TOKEN=
NFSE_CITY_CODE=
NFSE_DEFAULT_SERVICE_CODE=


# Chave server-side para criptografar arquivo/senha do certificado digital A1
NFSE_CERTIFICATE_ENCRYPTION_KEY=

# IA server-side (não expor no frontend)
# Provedor principal: DeepSeek. Fallback opcional: OpenAI.
DEEPSEEK_API_KEY=""
DEEPSEEK_API_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_MODEL="deepseek-chat"
OPENAI_API_KEY=""
OPENAI_API_URL="https://api.openai.com/v1/chat/completions"
OPENAI_MODEL="gpt-4o-mini"
